# Exclude the local virtual environment
.venv/
venv/
env/

# Exclude local data caches, databases, and vector indexes
data/*
!data/faiss_index/
*.db
*.sqlite3

# Exclude Python bytecode caches
**/__pycache__/
*.pyc
*.pyo
*.pyd

# Exclude source control logs and IDE configurations
.git/
.gitignore
.vscode/
.idea/